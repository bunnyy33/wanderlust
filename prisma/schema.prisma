// Wanderlust — Premium Tourism Booking Platform
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Destination {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  country     String
  city        String?
  region      String?
  description String
  longDescription String?
  image       String
  heroImage   String?
  popular     Boolean  @default(false)
  featured    Boolean  @default(false)
  experiences Experience[]
  hotels      Hotel[]
  createdAt   DateTime @default(now())
}

model Experience {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  type            String   // TOUR | ACTIVITY | TRANSFER | CRUISE | ATTRACTION | ADVENTURE
  description     String
  longDescription String
  destinationId   String
  destination     Destination @relation(fields: [destinationId], references: [id])
  price           Float
  originalPrice   Float?
  currency        String   @default("USD")
  duration        String
  durationHours   Float    @default(4)
  rating          Float    @default(4.8)
  reviewCount     Int      @default(0)
  images          String   // JSON array of URLs
  highlights      String   // JSON array of strings
  itinerary       String   // JSON array of {time, title, description}
  includes        String   // JSON array
  excludes        String   // JSON array
  groupSize       Int      @default(12)
  language        String   @default("English")
  meetingPoint    String?
  cancellationPolicy String @default("Free cancellation up to 24 hours before the experience.")
  cancellationType String  @default("FLEXIBLE") // FLEXIBLE (24h) | MODERATE (48h) | STRICT (no refund)
  availability    Int      @default(20)
  bookedCount     Int      @default(0)
  vendorName      String   @default("Wanderlust Verified Partner")
  featured        Boolean  @default(false)
  bestseller      Boolean  @default(false)
  tags            String   @default("[]") // JSON array
  latitude        Float?
  longitude       Float?
  status          String   @default("ACTIVE") // ACTIVE | DRAFT | ARCHIVED
  bookings        Booking[]
  reviews         Review[]
  createdAt       DateTime @default(now())
}

model Hotel {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String
  longDescription String
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id])
  starRating    Int      @default(5)
  pricePerNight Float
  originalPrice Float?
  currency      String   @default("USD")
  images        String   // JSON array
  amenities     String   // JSON array
  roomTypes     String   // JSON array of {name, description, maxGuests, priceModifier}
  rating        Float    @default(4.8)
  reviewCount   Int      @default(0)
  checkInTime   String   @default("14:00")
  checkOutTime  String   @default("12:00")
  address       String?
  featured      Boolean  @default(false)
  status        String   @default("ACTIVE")
  bookings      Booking[]
  reviews       Review[]
  createdAt     DateTime @default(now())
}

model Booking {
  id            String   @id @default(cuid())
  reference     String   @unique
  experienceId  String?
  experience    Experience? @relation(fields: [experienceId], references: [id])
  hotelId       String?
  hotel         Hotel?     @relation(fields: [hotelId], references: [id])
  type          String   // EXPERIENCE | HOTEL
  checkInDate   DateTime
  checkOutDate  DateTime?
  guests        Int      @default(2)
  nights        Int      @default(1)
  unitPrice     Float
  addonsTotal   Float    @default(0)
  taxesAndFees  Float    @default(0)
  discount      Float    @default(0)
  totalAmount   Float
  currency      String   @default("USD")
  status        String   @default("CONFIRMED") // PENDING | CONFIRMED | COMPLETED | CANCELLED | REFUNDED
  paymentStatus String   @default("PAID") // UNPAID | PAID | REFUNDED
  paymentMethod String   @default("CARD")
  customerName  String
  customerEmail String
  customerPhone String?
  specialRequests String?
  couponCode    String?
  // Fraud detection
  ipAddress     String?
  userAgent     String?
  fraudScore    Int      @default(0)
  fraudSignals  String   @default("[]")
  isFlagged     Boolean  @default(false)
  manualReview  String   @default("PENDING")
  createdAt     DateTime @default(now())
}

model Review {
  id            String   @id @default(cuid())
  experienceId  String?
  experience    Experience? @relation(fields: [experienceId], references: [id])
  hotelId       String?
  hotel         Hotel?     @relation(fields: [hotelId], references: [id])
  authorName    String
  authorAvatar  String?
  authorCountry String?
  rating        Float
  title         String
  comment       String
  travelDate    String?
  helpful       Int      @default(0)
  verified      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String
  discountType  String   // PERCENT | FIXED
  discountValue Float
  minSpend      Float    @default(0)
  maxDiscount   Float?
  validFrom     DateTime @default(now())
  validTo       DateTime?
  usageLimit    Int      @default(1000)
  usedCount     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model AiSettings {
  id            String   @id @default("singleton")
  systemPrompt  String   @default("")  // Custom instructions for chat concierge
  businessInfo  String   @default("")  // Policies, hours, contact, FAQ answers
  persona       String   @default("Wanderlust Concierge")  // Display name
  plannerPrompt String   @default("")  // Custom instructions for trip planner
  updatedAt     DateTime @updatedAt
}

model ChatLog {
  id         String   @id @default(cuid())
  sessionId  String
  userMessage String
  aiReply    String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

model Wishlist {
  id            String   @id @default(cuid())
  sessionId     String
  experienceId  String?
  hotelId       String?
  createdAt     DateTime @default(now())
}

model EmailLog {
  id         String   @id @default(cuid())
  toEmail    String
  subject    String
  body       String
  type       String   // BOOKING_CONFIRMATION | REVIEW_REQUEST | WELCOME | MANUAL
  status     String   @default("SENT") // SENT | FAILED | PENDING
  relatedRef String?  // booking reference, etc.
  createdAt  DateTime @default(now())
}

// ============================================================
// AGENCY BOOKING SYSTEM — B2B travel agency management
// ============================================================

// Employees who use the agency dashboard
model Employee {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("JUNIOR_AGENT") // ADMIN | SENIOR_AGENT | JUNIOR_AGENT | ACCOUNTS
  phone        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  reservations Reservation[]
  tours       TourBooking[]
  transports  TransportBooking[]
  hotels      HotelBooking[]
}

// Master reservation — one customer, one invoice, multiple services
model Reservation {
  id              String   @id @default(cuid())
  reference       String   @unique // WL-RES-064289
  invoiceNumber   String   @unique // WL-INV-064289

  // Customer info
  customerId      String?
  customerName    String
  customerEmail   String
  customerPhone   String?
  isGuest         Boolean  @default(false) // guest checkout (no customer record)

  // Booking metadata
  orderDate       DateTime @default(now())
  invoiceDate     DateTime?
  bookingStatus   String   @default("PENDING") // PENDING | SUPPLIER_PENDING | CUSTOMER_CONFIRMED | CONFIRMED | COMPLETED | CANCELLED
  saleById        String?  // employee who made the sale
  createdById     String?  // employee who created the record
  updatedById     String?

  // Financial
  invoiceType     String   @default("TAXABLE") // TAXABLE | ZERO_RATED | EXEMPT
  currency        String   @default("AED")
  subTotal        Float    @default(0)
  vatAmount       Float    @default(0)
  totalAmount     Float    @default(0)
  amountPaid      Float    @default(0)
  balanceDue      Float    @default(0)

  // Additional
  remarks         String?
  termsAccepted   Boolean  @default(false)

  // Fraud detection (mirrors website Booking model — used by agency verification dialog)
  ipAddress       String?
  userAgent       String?
  fraudScore      Int      @default(0)
  fraudSignals    String   @default("[]") // JSON array of strings
  isFlagged       Boolean  @default(false)
  manualReview    String   @default("PENDING") // PENDING | REAL | SPAM

  // Relations
  employee        Employee? @relation(fields: [saleById], references: [id])
  tours           TourBooking[]
  transports      TransportBooking[]
  hotels          HotelBooking[]
  flights         FlightBooking[]
  visas           VisaBooking[]
  extras          ExtraBooking[]
  guests          Guest[]
  payments        Payment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Guest details for a reservation (can have multiple guests)
model Guest {
  id            String   @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  title         String   @default("Mr") // Mr | Mrs | Miss | Master | Dr
  fullName      String
  email         String?
  phone         String?
  passportNumber String?
  paxType       String   @default("ADULT") // ADULT | CHILD | INFANT
  nationality   String?
  dateOfBirth   DateTime?
  createdAt     DateTime @default(now())
}

// Tour booking — linked to a reservation
model TourBooking {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id])

  // Tour details
  tourId          String?  // link to Experience catalog
  tourName        String   // free text or from catalog
  tourOption      String?  // e.g. "DUBAI PARKS 1 DAY 2 PARK PASS"
  transferOption  String   @default("WITHOUT_TRANSFER") // WITHOUT_TRANSFER | SHARED | PRIVATE
  pickupLocation  String?
  tourDate        DateTime
  pickupTime      String?
  timeSlot        String?

  // Pax
  noOfAdults      Int      @default(0)
  noOfChildren    Int      @default(0)

  // Supplier
  supplierId      String?
  supplierName    String?
  confirmationNumber String?

  // Status
  status          String   @default("INITIATED") // INITIATED | SUPPLIER_CONFIRMED | CUSTOMER_CONFIRMED | CONFIRMED | CANCELLED
  comments        String?

  // Pricing — Cost (net)
  costUnit        String   @default("PER_PERSON") // PER_PERSON | PER_BOOKING
  adultCostRate   Float    @default(0)  // net rate per adult
  childCostRate   Float    @default(0)  // net rate per child
  carCostRate     Float    @default(0)  // transfer cost
  netAdultRate    Float    @default(0)  // calculated: adultCostRate * noOfAdults
  netChildRate    Float    @default(0)  // calculated: childCostRate * noOfChildren
  totalCost       Float    @default(0)  // calculated: netAdultRate + netChildRate + carCostRate

  // Pricing — Sell (to customer)
  adultSellRate   Float    @default(0)
  childSellRate   Float    @default(0)
  carSellRate     Float    @default(0)
  sellNetAdult    Float    @default(0)  // calculated
  sellNetChild    Float    @default(0)  // calculated
  totalSell       Float    @default(0)  // calculated

  // Show on voucher
  showOnVoucher   Boolean  @default(true)

  // Audit
  createdBy       String?
  employee        Employee? @relation(fields: [createdBy], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Transport booking — linked to a reservation
model TransportBooking {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id])

  // Transport details
  carType         String   @default("SEDAN") // SEDAN | SUV | MINIVAN | VAN | LUXURY | COACH
  noOfPax         Int      @default(1)
  transportType   String   @default("ARRIVAL") // ARRIVAL | DEPARTURE | INTERCITY | HOURLY
  pickupDateTime  DateTime
  pickupLocation  String
  dropoffLocation String
  flightNumber    String?

  // Supplier
  supplierId      String?
  supplierName    String?
  contactNumber   String?
  confirmationNumber String?

  // Status
  status          String   @default("INITIATED")
  comments        String?

  // Pricing
  netRate         Float    @default(0)  // cost price
  sellRate        Float    @default(0)  // selling price
  margin          Float    @default(0)  // calculated: sellRate - netRate

  // Show on voucher
  showOnVoucher   Boolean  @default(true)

  // Audit
  createdBy       String?
  employee        Employee? @relation(fields: [createdBy], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Hotel booking — linked to a reservation
model HotelBooking {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id])

  // Hotel details
  hotelId         String?  // link to Hotel catalog
  hotelName       String
  roomType        String   // e.g. "Sky Pool Suite"
  mealPlan        String   @default("BB") // BB | HB | FB | AI
  checkInDate     DateTime
  checkOutDate    DateTime
  nights          Int      @default(1)
  noOfRooms       Int      @default(1)
  noOfAdults      Int      @default(1)
  noOfChildren    Int      @default(0)

  // Supplier
  supplierId      String?
  supplierName    String?
  confirmationNumber String?

  // Status
  status          String   @default("INITIATED")
  comments        String?

  // Pricing — Cost (net)
  costPerNight    Float    @default(0)
  totalCost       Float    @default(0)  // calculated: costPerNight * nights * rooms

  // Pricing — Sell
  sellPerNight    Float    @default(0)
  totalSell       Float    @default(0)  // calculated

  // Show on voucher
  showOnVoucher   Boolean  @default(true)

  // Audit
  createdBy       String?
  employee        Employee? @relation(fields: [createdBy], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Supplier management
model Supplier {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("TOUR") // TOUR | HOTEL | TRANSPORT | VISA | FLIGHT
  contactPerson   String?
  email           String?
  phone           String?
  whatsapp        String?
  address         String?
  city            String?
  country         String?

  // Supplier portal login — email + access code (shared per supplier for now)
  accessCode      String?

  // Contracted rates info
  currency        String   @default("AED")
  paymentTerms    String?  // e.g. "30 days credit", "Prepaid", "On arrival"
  markupType      String   @default("PERCENT") // PERCENT | FIXED
  markupValue     Float    @default(20) // default markup %

  // Status
  active          Boolean  @default(true)
  rating          Int      @default(5) // 1-5 reliability rating

  createdAt       DateTime @default(now())
}

// Payment tracking
model Payment {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id])

  amount          Float
  currency        String   @default("AED")
  paymentMethod   String   @default("CASH") // CASH | CARD | BANK_TRANSFER | WHATSAPP | ONLINE
  paymentDate     DateTime @default(now())
  reference       String?  // bank transfer ref / payment gateway ref
  status          String   @default("RECEIVED") // PENDING | RECEIVED | REFUNDED
  notes           String?

  receivedBy      String?  // employee who received the payment
  createdAt       DateTime @default(now())
}

// Flight booking (operational record)
model FlightBooking {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id])

  airline         String   @default("")
  flightNumber    String?
  flightType      String   @default("ONE_WAY") // ONE_WAY | ROUND_TRIP | MULTI_CITY
  cabinClass      String   @default("ECONOMY") // ECONOMY | PREMIUM | BUSINESS | FIRST
  origin          String   @default("")
  destination     String   @default("")
  departDate      DateTime
  returnDate      DateTime?

  noOfAdults      Int      @default(1)
  noOfChildren    Int      @default(0)
  noOfInfants     Int      @default(0)

  supplierId      String?
  supplierName    String?
  pnr             String?
  confirmationNumber String?
  status          String   @default("INITIATED")
  comments        String?

  // Pricing
  adultCostRate   Float    @default(0)
  childCostRate   Float    @default(0)
  infantCostRate  Float    @default(0)
  totalCost       Float    @default(0)
  adultSellRate   Float    @default(0)
  childSellRate   Float    @default(0)
  infantSellRate  Float    @default(0)
  totalSell       Float    @default(0)

  showOnVoucher   Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Visa booking (operational record)
model VisaBooking {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id])

  visaType        String   @default("TOURIST") // TOURIST | TRANSIT | BUSINESS | STUDENT | WORK
  destinationCountry String @default("")
  visaDuration    String?
  processingType  String   @default("NORMAL") // NORMAL | URGENT | EXPRESS
  applicationDate DateTime @default(now())
  travelDate      DateTime?

  noOfAdults      Int      @default(1)
  noOfChildren    Int      @default(0)

  supplierId      String?
  supplierName    String?
  applicationNumber String?
  confirmationNumber String?
  status          String   @default("INITIATED")
  comments        String?

  // Pricing
  adultCostRate   Float    @default(0)
  childCostRate   Float    @default(0)
  totalCost       Float    @default(0)
  adultSellRate   Float    @default(0)
  childSellRate   Float    @default(0)
  totalSell       Float    @default(0)

  showOnVoucher   Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Extras booking (insurance, SIM, lounge, photographer, etc.)
model ExtraBooking {
  id              String   @id @default(cuid())
  reservationId   String
  reservation     Reservation @relation(fields: [reservationId], references: [id])

  extraName       String   @default("")
  extraOption     String?
  serviceDate     DateTime?
  quantity        Int      @default(1)

  supplierId      String?
  supplierName    String?
  confirmationNumber String?
  status          String   @default("INITIATED")
  comments        String?

  // Pricing
  costRate        Float    @default(0)
  totalCost       Float    @default(0)
  sellRate        Float    @default(0)
  totalSell       Float    @default(0)

  showOnVoucher   Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// AUDIT LOG — tracks all mutations to reservation-related entities
// ============================================================
model AuditLog {
  id            String   @id @default(cuid())
  reservationId String?
  employeeId    String?
  employeeName  String?
  action        String   // CREATE | UPDATE | DELETE | STATUS_CHANGE | EMAIL_SENT | VOUCHER | INVOICE
  entityType    String   // RESERVATION | TOUR | HOTEL | TRANSPORT | FLIGHT | VISA | EXTRA | PAYMENT | GUEST
  entityId      String?
  changes       String   @default("{}") // JSON string of { field: { old, new } }
  ipAddress     String?
  createdAt     DateTime @default(now())
}

// ============================================================
// WEBHOOKS — outbound integrations fired on booking events
// ============================================================
model Webhook {
  id        String   @id @default(cuid())
  url       String
  events    String   @default("BOOKING_STATUS_CHANGE") // comma-separated
  active    Boolean  @default(true)
  secret    String?
  createdAt DateTime @default(now())
}
